generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Setting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String?
  updatedAt DateTime @updatedAt
}

model Artist {
  id        String   @id
  name      String
  slug      String   @unique
  genre     String?
  origin    String?
  bio       String?
  image     String?
  imageAlt  String?
  tags        Json?
  socialLinks Json?
  featured    Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

model Event {
  id          String   @id
  title       String
  slug        String   @unique
  eventDate   DateTime?
  venue       String?
  city        String?
  country     String?  @default("Mauritius")
  genre       String?
  image       String?
  imageAlt    String?
  description String?
  artists     Json?
  featured    Boolean  @default(false)
  soldOut     Boolean  @default(false)
  eventTime   String?  // e.g. "19:30"
  createdAt   DateTime @default(now())
}

model News {
  id          String   @id
  title       String
  slug        String   @unique
  excerpt     String?
  content     String?
  coverImage  String?
  coverAlt    String?
  author      String?  @default("IREY PROD")
  status      String   @default("draft")
  publishedAt DateTime?
  createdAt   DateTime @default(now())
}

model BookingSubmission {
  id         Int      @id @default(autoincrement())
  artistName String?
  fullName   String
  email      String
  address    String?
  dateTime   DateTime?
  message    String?
  status     String   @default("new")
  createdAt  DateTime @default(now())
}

model ContactSubmission {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  budget    String?
  timeframe String?
  project   String?
  status    String   @default("new")
  createdAt DateTime @default(now())
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  action    String
  resource  String?
  details   String?
  createdAt DateTime @default(now())
}