# =============================================================================
# IREY PROD — Production Environment Variables
# Deploy this file to your server (never commit to version control)
# =============================================================================

# Disable Next.js telemetry during build
NEXT_TELEMETRY_DISABLED=1

# -----------------------------------------------------------------------------
# SUPABASE — Database & Auth
# https://supabase.com/dashboard → Project Settings → API
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Used by the send-email Edge Function (server-side only)
# https://supabase.com/dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# -----------------------------------------------------------------------------
# RESEND — Transactional Email
# https://resend.com/api-keys
# Used by: supabase/functions/send-email (booking & contact notifications)
# -----------------------------------------------------------------------------
RESEND_API_KEY=your-resend-api-key

# -----------------------------------------------------------------------------
# GOOGLE ANALYTICS 4
# NEXT_PUBLIC_GA_MEASUREMENT_ID → https://analytics.google.com → Admin → Data Streams → Measurement ID (G-XXXXXXXX)
# GA4_PROPERTY_ID              → Admin → Property Settings → Property ID (numeric, e.g. 123456789)
# GA4_API_SECRET               → Admin → Service Accounts → create key → OAuth access token
# -----------------------------------------------------------------------------
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
GA4_PROPERTY_ID=123456789
GA4_API_SECRET=your-ga4-service-account-oauth-token

# -----------------------------------------------------------------------------
# DEPLOYMENT URL
# The canonical public URL of this deployment (no trailing slash)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://talowa5941.builtwithrocket.new

# -----------------------------------------------------------------------------
# GOOGLE ADSENSE (optional)
# https://adsense.google.com → Account → Account information → Publisher ID (ca-pub-XXXXXXXX)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_ADSENSE_ID=ca-pub-XXXXXXXXXX

# -----------------------------------------------------------------------------
# AI / LLM APIs (optional — only needed if AI features are enabled)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=your-openai-api-key
GEMINI_API_KEY=your-gemini-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
PERPLEXITY_API_KEY=your-perplexity-api-key

# -----------------------------------------------------------------------------
# STRIPE (optional — only needed if payment features are enabled)
# https://dashboard.stripe.com/apikeys
# -----------------------------------------------------------------------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your-stripe-publishable-key
